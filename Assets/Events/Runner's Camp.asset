  m_Name: Runner's Camp
  m_EditorClassIdentifier: Assembly-CSharp::ExplorerEvent
  Title: Runner's Camp
  Description: A sharp pain in the leg. Push through or rest?
  Targeting: 0
  BaseTimeCost: 0
  Choices:
  - Label: Push Through
    VagueHint: Willpower has limits.
    StatCheck: 1
    RequiresCheck: 1
    ExtraTimeCostOnSuccess: 0
    ExtraTimeCostOnFail: 0
    IntelGain: 0
    StaminaCost: 5
    SuccessMessage: Through gritted teeth you push on.
    IntelGainOnFail: 0
    StaminaCostOnFail: 25
    FailureMessage: The pain is unbearable
  - Label: Rest briefly
    VagueHint: Costs time, but might be worth it.
    StatCheck: 1
    RequiresCheck: 1
    ExtraTimeCostOnSuccess: 0.1
    ExtraTimeCostOnFail: 0.1
    IntelGain: 0
    StaminaCost: 0
    SuccessMessage: You're ready to move on.
    IntelGainOnFail: 0
    StaminaCostOnFail: 5
    FailureMessage: Still hurts but you can continue.
