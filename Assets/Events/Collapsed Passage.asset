  m_Script: {fileID: 11500000, guid: 04ccb2f1cbcd09c42a3acc3e0434ca68, type: 3}
  m_Name: Collapsed Passage
  m_EditorClassIdentifier: Assembly-CSharp::ExplorerEvent
  Title: Collapsed Passage
  Description: As you turn a corner the passage forward is blocked by a large amount
    of debries. You can see a small gap you could maybe squeeze through if you moved
    some of it away.
  Targeting: 1
  BaseTimeCost: 0.1
  Choices:
  - Label: Clear the debris
    VagueHint: You'd want your Strongest explorer on this
    StatCheck: 2
    RequiresCheck: 1
    ExtraTimeCostOnSuccess: 0
    ExtraTimeCostOnFail: 0
    IntelGain: 6
    StaminaCost: 0
    SuccessMessage: They effortlessly clear a passage.
    IntelGainOnFail: 0
    StaminaCostOnFail: 20
    FailureMessage: 'It takes a lot out of them '
  - Label: Find another way
    VagueHint: Who knows how long it will take.
    StatCheck: 0
    RequiresCheck: 0
    ExtraTimeCostOnSuccess: 0.05
    ExtraTimeCostOnFail: 0.1
    IntelGain: 0
    StaminaCost: 0
    SuccessMessage: It takes a bit but they manage to find a way forward.
    IntelGainOnFail: 0
    StaminaCostOnFail: 0
    FailureMessage: 'They walk in circles for a while. '
